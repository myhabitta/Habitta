---
export const prerender = false;

import PortalLayout from '@/layouts/PortalLayout.astro';
import { createClient } from '@supabase/supabase-js';
import { PHASE_LABELS, PHASE_SHORT_LABELS, PHASE_COLORS } from '@habitta/types';
import type { ConstructionPhase } from '@habitta/types';

const url = import.meta.env.PUBLIC_SUPABASE_URL || process.env.PUBLIC_SUPABASE_URL;
const key = import.meta.env.SUPABASE_SERVICE_ROLE_KEY || process.env.SUPABASE_SERVICE_ROLE_KEY;
const supabase = createClient(url, key, { auth: { autoRefreshToken: false, persistSession: false } });

const { cedula } = Astro.params;
if (!cedula) return Astro.redirect('/portal');

const { data: client } = await supabase
  .from('clients')
  .select('*, project:projects(id, name, city), package:packages(id, name, price, delivery_days)')
  .eq('cedula', cedula)
  .single();

if (!client) return Astro.redirect('/portal');

const phases: ConstructionPhase[] = [0, 1, 2, 3, 4, 5];
const currentPhase = client.construction_phase as ConstructionPhase;
const progressPercent = Math.round((currentPhase / 5) * 100);
const colors = PHASE_COLORS[currentPhase];
const isTerminado = currentPhase === 5;
const isSinIniciar = currentPhase === 0;

const PHASE_MESSAGES: Record<ConstructionPhase, { title: string; subtitle: string }> = {
  0: { title: 'Tu proyecto está por comenzar', subtitle: 'Pronto iniciaremos la transformación de tu apartamento' },
  1: { title: '¡Ya estamos en obra!', subtitle: 'Los cimientos de tu hogar toman forma' },
  2: { title: '¡Gran avance!', subtitle: 'Tu apartamento se transforma día a día' },
  3: { title: '¡Ya casi!', subtitle: 'Los detalles que harán único tu hogar' },
  4: { title: '¡Últimos toques!', subtitle: 'Estamos perfeccionando cada detalle' },
  5: { title: '¡Felicitaciones!', subtitle: 'Tu apartamento está listo para ti' },
};

const formatDate = (dateStr: string | null): string => {
  if (!dateStr) return '—';
  return new Intl.DateTimeFormat('es-CO', {
    day: '2-digit',
    month: 'long',
    year: 'numeric',
  }).format(new Date(dateStr));
};
---

<PortalLayout
  title="Tu apartamento"
  phaseColor={colors.solid}
  phaseBg={isTerminado ? '#f0f7ed' : isSinIniciar ? '#fef6f4' : colors.bg}
>
  <div class="space-y-5">

    <!-- ══════ HERO: Progress showcase ══════ -->
    <div class="animate-fade-up text-center">
      <!-- Avatar -->
      <div
        class="animate-scale-in mx-auto mb-5 flex h-20 w-20 items-center justify-center rounded-full shadow-xl"
        style={`background: linear-gradient(135deg, ${colors.solid}, ${colors.text}); box-shadow: 0 8px 32px ${colors.solid}33;`}
      >
        <span class="font-display text-3xl font-bold text-white">
          {client.first_name?.charAt(0)}{client.last_name?.charAt(0)}
        </span>
      </div>

      <!-- Greeting -->
      <h1 class="font-display text-[28px] font-bold text-[#1e1a1b]">
        Hola, {client.first_name}
      </h1>
      <p class="mt-1 font-sans text-sm text-[#6e6762]">
        {PHASE_MESSAGES[currentPhase].subtitle}
      </p>
    </div>

    <!-- ══════ PROGRESS RING ══════ -->
    <div class="animate-fade-up-delay">
      <div
        class:list={[
          'relative overflow-hidden rounded-3xl border p-6 shadow-xl backdrop-blur-sm',
          { 'animate-celebrate': isTerminado },
        ]}
        style={`
          background: linear-gradient(135deg, white 0%, ${colors.bg} 100%);
          border-color: ${colors.solid}20;
          box-shadow: 0 4px 24px ${colors.solid}15, 0 1px 3px rgba(0,0,0,0.04);
        `}
      >
        <!-- Shimmer overlay for completed -->
        {isTerminado && (
          <div class="animate-shimmer pointer-events-none absolute inset-0 rounded-3xl"></div>
        )}

        <div class="relative flex flex-col items-center gap-4">
          <!-- Phase title -->
          <p
            class="font-display text-lg font-bold"
            style={`color: ${colors.text};`}
          >
            {PHASE_MESSAGES[currentPhase].title}
          </p>

          <!-- Big percentage -->
          <div class="relative flex h-32 w-32 items-center justify-center">
            <!-- Background ring -->
            <svg class="absolute inset-0 h-full w-full -rotate-90" viewBox="0 0 120 120">
              <circle cx="60" cy="60" r="52" fill="none" stroke="#f3f1ed" stroke-width="8" />
              <circle
                cx="60" cy="60" r="52" fill="none"
                stroke={colors.solid}
                stroke-width="8"
                stroke-linecap="round"
                stroke-dasharray={`${progressPercent * 3.27} 327`}
                class="transition-all duration-1000"
                style="filter: drop-shadow(0 0 6px ${colors.solid}40);"
              />
            </svg>
            <div class="text-center">
              <span
                class="font-display text-4xl font-bold"
                style={`color: ${colors.text};`}
              >
                {progressPercent}
              </span>
              <span class="font-sans text-sm font-semibold text-[#9b9490]">%</span>
            </div>
          </div>

          <!-- Current phase label -->
          <div
            class="rounded-full px-4 py-1.5"
            style={`background-color: ${colors.bg}; border: 1px solid ${colors.solid}25;`}
          >
            <span class="font-sans text-sm font-bold" style={`color: ${colors.text};`}>
              {isSinIniciar || isTerminado
                ? PHASE_LABELS[currentPhase]
                : `${PHASE_SHORT_LABELS[currentPhase]}: ${PHASE_LABELS[currentPhase]}`}
            </span>
          </div>

          <!-- Mini progress bar -->
          <div class="mt-1 h-1.5 w-full overflow-hidden rounded-full bg-[#f3f1ed]">
            <div
              class="animate-progress-fill h-full rounded-full"
              style={`width: ${progressPercent}%; background: linear-gradient(90deg, ${colors.solid}, ${colors.text});`}
            ></div>
          </div>
        </div>
      </div>
    </div>

    <!-- ══════ CONFETTI for Terminado ══════ -->
    {isTerminado && (
      <div class="pointer-events-none fixed inset-0 z-50 overflow-hidden" aria-hidden="true">
        {Array.from({ length: 20 }).map((_, i) => (
          <div
            style={`
              position: absolute;
              left: ${5 + (i * 4.7) % 90}%;
              top: -20px;
              width: ${6 + (i % 4) * 2}px;
              height: ${6 + (i % 4) * 2}px;
              border-radius: ${i % 3 === 0 ? '50%' : '2px'};
              background: ${['hsl(130 50% 38%)', 'hsl(45 80% 50%)', 'hsl(200 60% 50%)', 'hsl(25 80% 50%)', 'hsl(0 70% 50%)'][i % 5]};
              animation: confettiDrop ${1.5 + (i % 8) * 0.3}s ease-in ${(i % 10) * 0.15}s both;
            `}
          ></div>
        ))}
      </div>
    )}

    <!-- ══════ INFO CARD ══════ -->
    <div class="animate-fade-up-delay-2 rounded-2xl border border-[#e8e4de]/60 bg-white/90 p-6 shadow-lg shadow-black/[0.03] backdrop-blur-sm">
      <div class="mb-4 flex items-center gap-2">
        <div
          class="flex h-8 w-8 items-center justify-center rounded-lg"
          style={`background-color: ${colors.bg};`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" style={`color: ${colors.text};`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
          </svg>
        </div>
        <h2 class="font-display text-base font-bold text-[#1e1a1b]">Tu apartamento</h2>
      </div>

      <div class="flex flex-col gap-3.5">
        <div class="flex items-center justify-between">
          <span class="font-sans text-xs font-medium uppercase tracking-wider text-[#9b9490]">Proyecto</span>
          <span class="font-sans text-sm font-semibold text-[#1e1a1b]">{client.project.name}</span>
        </div>
        <div class="h-px bg-gradient-to-r from-transparent via-[#e8e4de] to-transparent"></div>
        <div class="flex items-center justify-between">
          <span class="font-sans text-xs font-medium uppercase tracking-wider text-[#9b9490]">Paquete</span>
          <span
            class="inline-flex items-center rounded-full px-2.5 py-0.5 font-sans text-sm font-semibold"
            style={`background-color: ${colors.bg}; color: ${colors.text};`}
          >
            {client.package.name}
          </span>
        </div>
        <div class="h-px bg-gradient-to-r from-transparent via-[#e8e4de] to-transparent"></div>
        <div class="flex items-center justify-between">
          <span class="font-sans text-xs font-medium uppercase tracking-wider text-[#9b9490]">Apartamento</span>
          <span class="font-sans text-sm font-semibold text-[#1e1a1b]">
            {client.tower ? `Torre ${client.tower} · ` : ''}{client.apartment_number ?? '—'}
          </span>
        </div>
        {client.work_start_date && (
          <Fragment>
            <div class="h-px bg-gradient-to-r from-transparent via-[#e8e4de] to-transparent"></div>
            <div class="flex items-center justify-between">
              <span class="font-sans text-xs font-medium uppercase tracking-wider text-[#9b9490]">Inicio de obra</span>
              <span class="font-sans text-sm font-semibold text-[#1e1a1b]">{formatDate(client.work_start_date)}</span>
            </div>
          </Fragment>
        )}
      </div>
    </div>

    <!-- ══════ TIMELINE ══════ -->
    <div class="animate-fade-up-delay-3 rounded-2xl border border-[#e8e4de]/60 bg-white/90 p-6 shadow-lg shadow-black/[0.03] backdrop-blur-sm">
      <div class="mb-5 flex items-center gap-2">
        <div
          class="flex h-8 w-8 items-center justify-center rounded-lg"
          style={`background-color: ${colors.bg};`}
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" style={`color: ${colors.text};`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
          </svg>
        </div>
        <h2 class="font-display text-base font-bold text-[#1e1a1b]">Detalle del avance</h2>
      </div>

      <div class="flex flex-col gap-0">
        {phases.map((phase, i) => {
          const isCompleted = phase < currentPhase;
          const isActive = phase === currentPhase;
          const isPending = phase > currentPhase;
          const isLast = i === phases.length - 1;
          const phaseIsTerminado = phase === 5;
          const phaseIsSinIniciar = phase === 0;
          const pc = PHASE_COLORS[phase as ConstructionPhase];

          return (
            <div
              class="flex gap-4"
              style={`animation: fadeUp 0.4s cubic-bezier(0.22,1,0.36,1) ${0.4 + i * 0.08}s both;`}
            >
              <div class="flex flex-col items-center">
                <div
                  class:list={[
                    'flex h-11 w-11 shrink-0 items-center justify-center rounded-full font-sans text-sm font-bold transition-all',
                    { 'ring-4': isActive },
                  ]}
                  style={{
                    backgroundColor: isCompleted || isActive ? pc.solid : '#f3f1ed',
                    color: isCompleted || isActive ? '#ffffff' : '#b5afa9',
                    boxShadow: isActive ? `0 4px 20px ${pc.solid}40` : isCompleted ? `0 2px 8px ${pc.solid}25` : 'none',
                    ringColor: isActive ? `${pc.solid}20` : 'transparent',
                  }}
                >
                  {isCompleted ? (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                  ) : phaseIsTerminado ? (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9" />
                    </svg>
                  ) : phaseIsSinIniciar ? (
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="8" />
                    </svg>
                  ) : (
                    phase
                  )}
                </div>
                {!isLast && (
                  <div
                    class="w-0.5 flex-1 min-h-[24px] transition-colors"
                    style={{
                      backgroundColor: isCompleted ? pc.solid : '#e8e4de',
                    }}
                  ></div>
                )}
              </div>

              <div class:list={['pb-6', { 'pb-0': isLast }]}>
                <p
                  class="font-sans text-sm font-semibold leading-[44px]"
                  style={{
                    color: isActive || isCompleted ? pc.text : '#9b9490',
                  }}
                >
                  {phaseIsSinIniciar || phaseIsTerminado
                    ? PHASE_LABELS[phase as ConstructionPhase]
                    : `${PHASE_SHORT_LABELS[phase as ConstructionPhase]}: ${PHASE_LABELS[phase as ConstructionPhase]}`}
                </p>
                {isActive && (
                  <span
                    class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 font-sans text-xs font-semibold"
                    style={{ backgroundColor: pc.bg, color: pc.text, border: `1px solid ${pc.solid}20` }}
                  >
                    <span class="relative flex h-2 w-2">
                      <span class="absolute inline-flex h-full w-full animate-ping rounded-full opacity-75" style={{ backgroundColor: pc.solid }}></span>
                      <span class="relative inline-flex h-2 w-2 rounded-full" style={{ backgroundColor: pc.solid }}></span>
                    </span>
                    {phaseIsSinIniciar ? 'Aún no inicia' : phaseIsTerminado ? '¡Completado!' : 'En curso'}
                  </span>
                )}
                {isCompleted && (
                  <span class="inline-flex items-center gap-1 font-sans text-xs font-medium" style={{ color: pc.text }}>
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                    </svg>
                    Completada
                  </span>
                )}
                {isPending && (
                  <span class="font-sans text-xs text-[#c5c0ba]">
                    Pendiente
                  </span>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- ══════ CERRAR SESIÓN ══════ -->
    <div class="animate-fade-up-delay-3 pt-3">
      <a
        href="/portal"
        class="group flex w-full items-center justify-center gap-2.5 rounded-2xl bg-[#424832] px-5 py-3.5 font-sans text-sm font-semibold text-white shadow-md shadow-[#424832]/20 transition-all hover:bg-[#374028] hover:shadow-lg active:scale-[0.98]"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 transition-transform group-hover:-translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
        </svg>
        Cerrar sesión
      </a>
    </div>
  </div>
</PortalLayout>
