---
// Atom: EyebrowLabel
// Línea decorativa + texto uppercase. Introduce secciones con contexto.

interface Props {
  text: string;
  class?: string;
}

const { text, class: className = '' } = Astro.props;
---

<div class:list={['flex items-center gap-4', className]}>
  <span class="block h-px w-10 shrink-0 origin-left animate-draw-line bg-primary motion-reduce:animate-none"></span>
  <span class="text-[0.72rem] font-medium uppercase tracking-[0.18em] text-primary">
    {text}
  </span>
</div>
