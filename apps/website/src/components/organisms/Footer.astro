---
// Organism: Footer
// Dark footer with 4-column grid (brand + 3 link columns), social icons, bottom bar.

import homeData from '@/data/home.json';

const { footer } = homeData;
---

<footer class="border-t border-border" role="contentinfo">
  <div class="px-6 pb-8 pt-16 md:px-12 lg:px-24 lg:pt-20">
    <!-- Top Grid -->
    <div class="mb-12 grid grid-cols-1 gap-10 border-b border-border pb-12 sm:grid-cols-2 lg:mb-16 lg:grid-cols-4 lg:gap-16 lg:pb-16">
      <!-- Brand -->
      <div>
        <a
          href="/"
          class="mb-4 block font-display text-3xl font-normal text-ink no-underline"
        >
          {footer.brand.name}
        </a>
        <p class="mb-6 max-w-[230px] text-xs leading-relaxed text-muted lg:text-sm lg:leading-[1.75]">
          {footer.brand.description}
        </p>
        <div class="flex gap-5">
          {
            footer.social.map((item) => (
              <a
                href={item.href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-muted transition-colors duration-300 hover:text-brand"
                aria-label={item.name}
              >
                {item.name === 'Instagram' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <rect x="2" y="2" width="20" height="20" rx="5" />
                    <circle cx="12" cy="12" r="4" />
                    <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
                  </svg>
                )}
                {item.name === 'LinkedIn' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <rect x="2" y="2" width="20" height="20" rx="3" />
                    <path d="M7 10v7M7 7v.5M12 17v-4a2 2 0 014 0v4M12 10v7" />
                  </svg>
                )}
                {item.name === 'WhatsApp' && (
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                    <path d="M3 20l1.4-4A9 9 0 1012 21a9 9 0 01-4-1L3 20z" />
                    <path d="M9 9c0 5 6.5 7.5 8 5" />
                  </svg>
                )}
              </a>
            ))
          }
        </div>
      </div>

      <!-- Link Columns -->
      {
        footer.columns.map((col) => (
          <div>
            <h4 class="mb-5 text-[0.58rem] font-semibold uppercase tracking-[0.2em] text-muted">
              {col.title}
            </h4>
            <ul class="flex flex-col gap-3" role="list">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-xs text-ink-subtle no-underline transition-colors duration-300 hover:text-ink lg:text-sm"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <!-- Bottom Bar -->
    <div class="flex flex-col items-center justify-between gap-3 text-[0.65rem] tracking-[0.06em] text-muted sm:flex-row">
      <p>&copy; {footer.copyright}</p>
      <p>{footer.bottomTagline}</p>
    </div>
  </div>
</footer>
