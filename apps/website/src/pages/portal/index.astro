---
export const prerender = false;

import PortalLayout from '@/layouts/PortalLayout.astro';
---

<PortalLayout title="Portal del Cliente">
  <div class="animate-fade-up">
    <!-- Welcome illustration -->
    <div class="mb-8 text-center">
      <div
        class="mx-auto mb-5 flex h-20 w-20 items-center justify-center rounded-3xl shadow-lg"
        style="background: linear-gradient(135deg, #424832, #353d28); box-shadow: 0 8px 24px rgba(66,72,50,0.2);"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-10 w-10 text-white"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="1.5"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z"
          ></path>
        </svg>
      </div>
      <h1 class="font-display text-[28px] font-bold leading-tight text-[#1e1a1b]">
        Bienvenido a tu portal
      </h1>
      <p class="mx-auto mt-2 max-w-xs font-sans text-sm leading-relaxed text-[#6b635d]">
        Consulta el estado y avance de los acabados de tu apartamento
      </p>
    </div>

    <!-- Login card -->
    <div
      class="rounded-2xl border border-[#e8e4de]/60 bg-white/90 p-7 shadow-xl shadow-black/[0.04] backdrop-blur-sm"
    >
      <form id="portal-form" class="flex flex-col gap-5">
        <div class="flex flex-col gap-1.5">
          <label
            for="email"
            class="font-sans text-[13px] font-semibold uppercase tracking-wider text-[#9b9490]"
          >
            Correo electrónico
          </label>
          <div class="relative">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="pointer-events-none absolute left-3.5 top-1/2 h-4 w-4 -translate-y-1/2 text-[#c5c0ba]"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
            <input
              id="email"
              name="email"
              type="email"
              required
              placeholder="tu@correo.com"
              class="h-12 w-full rounded-xl border border-[#e8e4de] bg-[#faf8f5] pl-11 pr-4 font-sans text-sm text-[#1e1a1b] outline-none transition-all placeholder:text-[#c5c0ba] focus:border-[#424832] focus:ring-2 focus:ring-[#424832]/10"
            />
          </div>
        </div>

        <div class="flex flex-col gap-1.5">
          <label
            for="cedula"
            class="font-sans text-[13px] font-semibold uppercase tracking-wider text-[#9b9490]"
          >
            Número de cédula
          </label>
          <div class="relative">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="pointer-events-none absolute left-3.5 top-1/2 h-4 w-4 -translate-y-1/2 text-[#c5c0ba]"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"
              ></path>
            </svg>
            <input
              id="cedula"
              name="cedula"
              type="text"
              required
              inputmode="numeric"
              placeholder="Ej: 1234567890"
              class="h-12 w-full rounded-xl border border-[#e8e4de] bg-[#faf8f5] pl-11 pr-4 font-sans text-sm text-[#1e1a1b] outline-none transition-all placeholder:text-[#c5c0ba] focus:border-[#424832] focus:ring-2 focus:ring-[#424832]/10"
            />
          </div>
        </div>

        <div
          id="error-msg"
          class="hidden rounded-xl border border-red-200 bg-red-50 px-4 py-3 font-sans text-sm text-red-600"
        >
        </div>

        <button
          type="submit"
          class="group mt-1 flex h-12 w-full items-center justify-center gap-2 rounded-xl font-sans text-sm font-semibold text-white shadow-lg transition-all hover:shadow-xl active:scale-[0.98] disabled:opacity-50 disabled:shadow-none"
          style="background: linear-gradient(to right, #424832, #353d28); box-shadow: 0 4px 16px rgba(66,72,50,0.2);"
        >
          <span id="btn-text">Consultar mi apartamento</span>
          <svg
            id="btn-arrow"
            xmlns="http://www.w3.org/2000/svg"
            class="h-4 w-4 transition-transform group-hover:translate-x-0.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2.5"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"
            ></path>
          </svg>
          <svg
            id="btn-spinner"
            class="hidden h-4 w-4 animate-spin"
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
          >
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"
            ></circle>
            <path
              class="opacity-75"
              fill="currentColor"
              d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
            ></path>
          </svg>
        </button>
      </form>
    </div>

    <!-- Help text -->
    <p
      class="animate-fade-up-delay mt-6 text-center font-sans text-xs leading-relaxed text-[#9b9490]"
    >
      ¿Problemas para acceder? Contacta a tu asesor<br />
      o escríbenos a <span class="font-bold text-[#e8703a]">myhabitta.sas@gmail.com</span>
    </p>
  </div>

  <script>
    const form = document.getElementById('portal-form') as HTMLFormElement;
    const errorMsg = document.getElementById('error-msg') as HTMLDivElement;
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const btnText = document.getElementById('btn-text') as HTMLSpanElement;
    const btnArrow = document.getElementById('btn-arrow') as SVGElement;
    const btnSpinner = document.getElementById('btn-spinner') as SVGElement;

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorMsg.classList.add('hidden');
      btn.disabled = true;
      btnText.textContent = 'Verificando...';
      btnArrow.classList.add('hidden');
      btnSpinner.classList.remove('hidden');

      const email = (form.querySelector('#email') as HTMLInputElement).value.trim();
      const cedula = (form.querySelector('#cedula') as HTMLInputElement).value.trim();

      try {
        const res = await fetch('/api/portal/verify', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, cedula }),
        });

        const data = await res.json();

        if (!res.ok || data.error) {
          errorMsg.textContent = data.error || 'No se encontró un cliente con esos datos';
          errorMsg.classList.remove('hidden');
          btn.disabled = false;
          btnText.textContent = 'Consultar mi apartamento';
          btnArrow.classList.remove('hidden');
          btnSpinner.classList.add('hidden');
          return;
        }

        window.location.href = `/portal/${cedula}`;
      } catch {
        errorMsg.textContent = 'Error de conexión. Intenta de nuevo.';
        errorMsg.classList.remove('hidden');
        btn.disabled = false;
        btnText.textContent = 'Consultar mi apartamento';
        btnArrow.classList.remove('hidden');
        btnSpinner.classList.add('hidden');
      }
    });
  </script>
</PortalLayout>
