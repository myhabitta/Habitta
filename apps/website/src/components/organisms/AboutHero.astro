---
// Organism: AboutHero
// Hero heading for /nosotros — title + subtitle + alliance logos.

import AllianceSection from '@/components/organisms/AllianceSection.astro';
---

<section id="s-about-hero" class="relative overflow-hidden">
  <!-- ═══ HEADING ═══ -->
  <div class="relative z-20 px-6 pt-36 pb-12 md:px-12 md:pt-44 lg:px-24 lg:pt-52">
    <div class="mx-auto max-w-6xl text-center">
      <div
        id="ah-eyebrow"
        class="mb-6 flex items-center justify-center gap-3 opacity-0 translate-y-6"
        style="transition: all 0.8s cubic-bezier(0.16,1,0.3,1);"
      >
        <span class="block h-px w-8 bg-brand"></span>
        <span class="text-[0.6rem] uppercase tracking-[0.28em] text-brand">Sobre Habitta</span>
        <span class="block h-px w-8 bg-brand"></span>
      </div>

      <h1
        id="ah-heading"
        class="mx-auto max-w-4xl font-display text-[clamp(2.5rem,6.5vw,5.5rem)] font-thin leading-[0.92] tracking-tight opacity-0 translate-y-12"
        style="transition: all 1.1s cubic-bezier(0.16,1,0.3,1); transition-delay: 0.1s;"
      >
        Transformamos la experiencia<br />
        de <em class="italic text-sand">comprar vivienda</em> en Colombia
      </h1>

      <p
        id="ah-subtitle"
        class="mx-auto mt-6 max-w-lg font-display text-[clamp(0.95rem,1.4vw,1.15rem)] font-light italic leading-[1.7] text-ink opacity-0 translate-y-8 lg:mt-8"
        style="transition: all 0.9s cubic-bezier(0.16,1,0.3,1); transition-delay: 0.25s;"
      >
        Somos la única inmobiliaria en Colombia que integra construcción, diseño de interiores y tecnología bajo un mismo techo — para que cada familia reciba un hogar terminado a su medida.
      </p>
    </div>
  </div>

  <AllianceSection />
</section>

<script>
  function initAboutHero() {
    const headerEls = ['ah-eyebrow', 'ah-heading', 'ah-subtitle'];
    setTimeout(() => {
      headerEls.forEach((id) => {
        const el = document.getElementById(id);
        if (!el) return;
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
      });
    }, 250);
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAboutHero);
  } else {
    initAboutHero();
  }
</script>
