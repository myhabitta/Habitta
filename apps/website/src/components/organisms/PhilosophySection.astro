---
// Organism: PhilosophySection
// DARK SECTION — 3 pillars of company philosophy with large numbers and descriptions.
// Editorial layout with staggered reveals.

const pillars = [
  {
    number: '01',
    title: 'Calidad sin compromiso',
    description: 'Cada acabado, cada material, cada detalle es seleccionado con el mismo estándar que aplicaríamos en nuestro propio hogar. No hay atajos.',
  },
  {
    number: '02',
    title: 'Transparencia total',
    description: 'Desde el primer contacto hasta la entrega de llaves, cada paso del proceso es claro y documentado. Sin letra pequeña, sin sorpresas.',
  },
  {
    number: '03',
    title: 'Diseño con propósito',
    description: 'No decoramos espacios — diseñamos experiencias de vida. Cada decisión estética responde a cómo las familias realmente habitan sus hogares.',
  },
];
---

<section class="relative px-6 py-24 md:px-12 md:py-32 lg:px-24 lg:py-40">
  <div class="mx-auto max-w-6xl">
    <!-- Header -->
    <div class="mb-16 lg:mb-24">
      <div class="philosophy-el mb-5 flex items-center gap-3 opacity-0 -translate-x-6 transition-all duration-700 lg:mb-7" style="transition-timing-function: cubic-bezier(0.16,1,0.3,1);">
        <span class="block h-px w-10 bg-brand"></span>
        <span class="text-[0.6rem] uppercase tracking-[0.25em] text-brand">Nuestra filosofía</span>
      </div>

      <h2 class="philosophy-el max-w-xl font-display text-[clamp(2rem,4.5vw,4rem)] font-thin leading-[0.95] tracking-tight text-ink opacity-0 translate-y-10 transition-all duration-[1s]" style="transition-timing-function: cubic-bezier(0.16,1,0.3,1); transition-delay: 0.1s;">
        Lo que nos guía<br />
        <em class="italic text-sand">cada día</em>
      </h2>
    </div>

    <!-- Pillars -->
    <div class="grid grid-cols-1 gap-0 border-t border-border md:grid-cols-3">
      {pillars.map((pillar, i) => (
        <div
          class={`philosophy-pillar group py-10 opacity-0 translate-y-10 transition-all duration-[0.9s] lg:py-14 ${i > 0 ? 'border-t border-border md:border-t-0 md:border-l md:border-l-border md:pl-8 lg:pl-12' : ''} ${i < pillars.length - 1 ? 'md:pr-8 lg:pr-12' : ''}`}
          style={`transition-timing-function: cubic-bezier(0.16,1,0.3,1); transition-delay: ${0.15 + i * 0.12}s;`}
        >
          <!-- Number -->
          <span class="mb-6 block font-display text-5xl font-thin leading-none text-brand/20 transition-colors duration-500 group-hover:text-brand/50 lg:mb-8 lg:text-6xl">
            {pillar.number}
          </span>

          <!-- Title -->
          <h3 class="mb-3 font-display text-xl font-normal leading-[1.1] text-ink lg:mb-4 lg:text-2xl">
            {pillar.title}
          </h3>

          <!-- Description -->
          <p class="text-sm leading-[1.8] text-muted">
            {pillar.description}
          </p>

          <!-- Accent line -->
          <div class="mt-6 h-px w-8 bg-brand/30 transition-all duration-500 group-hover:w-14 group-hover:bg-brand/60 lg:mt-8"></div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  const phObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          el.style.opacity = '1';
          el.style.transform = 'translateY(0) translateX(0)';
          phObs.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll('.philosophy-el, .philosophy-pillar').forEach((el) => phObs.observe(el));
</script>
