---
// Organism: Hero
// Sticky parallax hero with watermark text, diagonal line, scroll-driven reveal.
// Three phases: watermark visible → overlay fades → content appears.

import homeData from '@/data/home.json';

const { hero } = homeData;
---

<section
  id="s-hero"
  class="relative"
  data-section="01"
  data-sname="Hero"
  style="height: 300vh;"
>
  <div class="sticky top-0 h-screen overflow-hidden">
    <!-- Background Image -->
    <div
      id="hero-bg"
      class="absolute inset-0 bg-cover bg-center transition-transform duration-700 ease-out"
      style={`background-image: url('${hero.bgImage}'); will-change: transform; transform: scale(1.1);`}
    ></div>

    <!-- Dark Overlay -->
    <div
      id="hero-overlay"
      class="absolute inset-0 bg-dark"
      style="opacity: 0.9; will-change: opacity;"
    ></div>

    <!-- Watermark -->
    <div
      id="hero-watermark"
      class="absolute inset-0 flex items-center justify-center"
      style="will-change: opacity, transform; transform: scale(0.85);"
    >
      <span
        class="whitespace-nowrap font-display text-[clamp(5rem,14vw,13rem)] font-thin uppercase tracking-[0.15em] text-ink"
      >
        HABITTA
      </span>
    </div>

    <!-- Diagonal Line -->
    <div
      id="hero-line"
      class="absolute left-0 right-0 h-px"
      style="top: 42%; background: linear-gradient(90deg, transparent 0%, rgba(232,112,58,0.4) 50%, transparent 100%); will-change: transform, opacity; transform: scaleX(0); transform-origin: center;"
    ></div>

    <!-- Content -->
    <div
      id="hero-content"
      class="absolute inset-x-0 bottom-0 px-6 pb-20 md:px-12 lg:px-24 lg:pb-28"
      style="will-change: opacity, transform; opacity: 0; transform: translateY(40px);"
    >
      <!-- Tag -->
      <p class="mb-4 flex items-center gap-3 text-[0.62rem] uppercase tracking-[0.25em] text-brand lg:mb-6">
        <span class="block h-px w-8 bg-brand"></span>
        {hero.tag}
      </p>

      <!-- Heading -->
      <h1 class="mb-4 font-display text-[clamp(2.5rem,6vw,5.8rem)] font-normal leading-[0.95] tracking-tight lg:mb-6">
        {hero.heading}<br />
        <em class="not-italic text-sand">{hero.headingAccent}</em>
      </h1>

      <!-- Subtitle -->
      <p class="mb-6 max-w-sm text-sm leading-relaxed text-ink-muted lg:mb-10 lg:max-w-md lg:text-base">
        {hero.subtitle}
      </p>

      <!-- CTAs -->
      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-8">
        <a
          href={hero.ctaPrimary.href}
          class="inline-flex items-center gap-3 bg-brand px-6 py-3 font-sans text-[0.73rem] font-bold uppercase tracking-[0.14em] text-white no-underline transition-colors duration-300 hover:bg-brand-dark lg:px-10 lg:py-4"
        >
          {hero.ctaPrimary.label}
          <svg width="14" height="10" viewBox="0 0 14 10" fill="none" aria-hidden="true">
            <path d="M9 1l4 4-4 4M0 5h13" stroke="currentColor" stroke-width="1.2" />
          </svg>
        </a>
        <a
          href={hero.ctaSecondary.href}
          class="flex items-center gap-2 text-[0.68rem] uppercase tracking-[0.16em] text-ink-subtle no-underline transition-colors duration-300 hover:text-ink"
        >
          <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
            <circle cx="5" cy="5" r="4" stroke="currentColor" stroke-width="1" />
            <path d="M5 3v2.5l1.5 1.5" stroke="currentColor" stroke-width="1" />
          </svg>
          {hero.ctaSecondary.label}
        </a>
      </div>
    </div>

    <!-- Scroll Indicator -->
    <div
      id="hero-scroll"
      class="absolute bottom-8 right-[5%] hidden flex-col items-center gap-2 md:flex"
      style="will-change: opacity;"
    >
      <div class="relative h-[60px] w-px overflow-hidden bg-border">
        <div class="absolute h-full w-full animate-scroll-line bg-brand"></div>
      </div>
      <span
        class="text-[0.56rem] uppercase tracking-[0.22em] text-ink-ghost"
        style="writing-mode: vertical-rl; transform: rotate(180deg);"
      >
        Scroll
      </span>
    </div>

    <!-- Coordinates -->
    <p
      class="absolute bottom-8 left-6 hidden text-[0.58rem] tracking-[0.14em] text-ink-ghost md:block lg:left-24"
    >
      {hero.coordinates}
    </p>
  </div>
</section>

<script>
  function initHero() {
    const section = document.getElementById('s-hero');
    const bg = document.getElementById('hero-bg');
    const overlay = document.getElementById('hero-overlay');
    const watermark = document.getElementById('hero-watermark');
    const line = document.getElementById('hero-line');
    const content = document.getElementById('hero-content');
    const scrollIndicator = document.getElementById('hero-scroll');

    if (!section || !bg || !overlay || !watermark || !line || !content) return;

    const clamp = (v: number, min: number, max: number) => Math.max(min, Math.min(max, v));
    const map = (v: number, a: number, b: number, c: number, d: number) =>
      c + (d - c) * clamp((v - a) / (b - a), 0, 1);

    function animate() {
      const h = section.offsetHeight - window.innerHeight;
      const p = h > 0 ? clamp(-section.getBoundingClientRect().top / h, 0, 1) : 0;

      overlay.style.opacity = String(map(p, 0, 0.22, 0.9, 0.35));

      watermark.style.opacity = String(map(p, 0.2, 0.4, 1, 0));
      watermark.style.transform = `scale(${map(p, 0, 0.3, 0.85, 1)})`;

      content.style.opacity = String(map(p, 0.3, 0.6, 0, 1));
      content.style.transform = `translateY(${map(p, 0.3, 0.6, 40, 0)}px)`;

      bg.style.transform = `translateY(${window.scrollY * 0.28}px) scale(${map(p, 0, 0.5, 1.1, 1)})`;

      line.style.opacity = String(map(p, 0.1, 0.5, 0.6, 0));
      line.style.transform = `scaleX(${map(p, 0, 0.2, 0, 1)})`;

      if (scrollIndicator) {
        scrollIndicator.style.opacity = String(map(p, 0, 0.25, 1, 0));
      }

      requestAnimationFrame(animate);
    }

    animate();
  }

  if (document.getElementById('loader')) {
    document.addEventListener('loader:complete', initHero, { once: true });
  } else {
    initHero();
  }
</script>
