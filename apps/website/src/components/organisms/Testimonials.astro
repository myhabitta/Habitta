---
// Organism: Testimonials
// Two-column testimonial grid with large decorative quote mark.
// Quotes and author info reveal on scroll.

import homeData from '@/data/home.json';

const { testimonials } = homeData;
---

<section
  id="testimonios"
  class="relative overflow-hidden px-6 py-20 md:px-12 lg:px-24 lg:py-36"
  data-section="07"
  data-sname="Testimonios"
>
  <!-- Decorative quote mark -->
  <span
    class="pointer-events-none absolute -top-8 right-[4%] select-none font-display text-[18rem] font-thin leading-none text-brand/[0.06] md:text-[24rem] lg:text-[28rem]"
    aria-hidden="true"
  >
    &ldquo;
  </span>

  <!-- Eyebrow -->
  <div class="reveal-el relative z-10 mb-8 flex items-center gap-3 text-[0.62rem] uppercase tracking-[0.22em] text-sand lg:mb-12">
    <span class="block h-px w-8 bg-sand"></span>
    {testimonials.eyebrow}
  </div>

  <!-- Grid -->
  <div class="relative z-10 grid grid-cols-1 gap-10 md:grid-cols-2 lg:gap-24">
    {
      testimonials.items.map((item, i) => (
        <div>
          <blockquote
            class="testimonial-quote border-t border-brand/[0.22] pt-6 font-display text-[clamp(1.1rem,2.3vw,1.8rem)] font-normal italic leading-[1.45] opacity-0 translate-y-8 transition-all duration-[0.9s] lg:pt-8"
            style={`transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1); transition-delay: ${i * 0.18}s;`}
          >
            &ldquo;{item.quote}&rdquo;
          </blockquote>
          <div
            class="testimonial-author mt-6 opacity-0 translate-y-3 transition-all duration-700 lg:mt-10"
            style={`transition-delay: ${0.2 + i * 0.14}s;`}
          >
            <span class="block font-sans text-xs font-bold uppercase tracking-[0.14em]">
              {item.name}
            </span>
            <span class="mt-1 block text-[0.68rem] tracking-[0.08em] text-ink-subtle">
              {item.detail}
            </span>
          </div>
        </div>
      ))
    }
  </div>
</section>

<script>
  document.addEventListener('astro:page-load', () => {
    // Reset elements so animations replay on navigation
    document.querySelectorAll('.testimonial-quote').forEach((el) => {
      el.classList.add('opacity-0', 'translate-y-8');
      el.classList.remove('opacity-100', 'translate-y-0');
    });
    document.querySelectorAll('.testimonial-author').forEach((el) => {
      el.classList.add('opacity-0', 'translate-y-3');
      el.classList.remove('opacity-100', 'translate-y-0');
    });

    const tObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('opacity-100', 'translate-y-0');
            entry.target.classList.remove('opacity-0', 'translate-y-8', 'translate-y-3');
            tObs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2 }
    );

    document.querySelectorAll('.testimonial-quote, .testimonial-author').forEach((el) =>
      tObs.observe(el)
    );
  });
</script>
