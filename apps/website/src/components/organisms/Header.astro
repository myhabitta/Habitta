---
// Organism: Header
// Dark transparent navbar that becomes solid on scroll with blur backdrop.
// Text logo (Cormorant Garamond), minimal nav links, CTA button.
// Responsive: hamburger menu on mobile.

import headerData from '@/data/header.json';

const { logo, nav: navLinks, cta } = headerData;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
const isHome = currentPath === '/';
const filteredNavLinks = navLinks.filter((link) => {
  if (isHome && link.href === '/') return false;
  if (!isHome && link.homeOnly) return false;
  return true;
});

function isActive(href: string): boolean {
  if (href.startsWith('#')) return false;
  const normalized = href.replace(/\/$/, '') || '/';
  if (normalized === '/') return currentPath === '/';
  return currentPath === normalized || currentPath.startsWith(normalized + '/');
}
---

<nav
  id="navbar"
  class="fixed inset-x-0 top-0 z-[800] flex items-center justify-between px-6 py-5 transition-all duration-500 md:px-10 lg:px-20"
>
  <!-- Logo -->
  <a
    href="/"
    class="font-display text-2xl font-normal tracking-[0.1em] text-ink no-underline"
    aria-label="Habitta - Inicio"
  >
    <img src={logo.src} alt={logo.alt} class="h-14 w-auto" />
  </a>

  <!-- Desktop Navigation -->
  <ul class="hidden items-center gap-10 lg:flex" role="list">
    {
      filteredNavLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'relative text-[0.68rem] font-medium uppercase tracking-[0.18em] no-underline transition-colors duration-300 after:absolute after:bottom-[-3px] after:left-0 after:h-px after:bg-brand after:transition-[width] after:duration-300',
              isActive(link.href)
                ? 'text-brand after:w-full'
                : 'text-ink-muted hover:text-ink after:w-0 hover:after:w-full',
            ]}
            aria-current={isActive(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>

  <!-- Desktop CTA -->
  <a
    href={cta.href}
    target="_blank"
    rel="noopener noreferrer"
    id="nav-cta"
    class="hidden border border-brand bg-brand px-6 py-2 font-sans text-[0.66rem] font-bold uppercase tracking-[0.16em] text-white no-underline transition-all duration-300 hover:bg-brand-dark hover:border-brand-dark lg:block"
  >
    {cta.label}
  </a>

  <!-- Mobile Hamburger -->
  <button
    id="mobile-menu-toggle"
    class="group relative z-[60] flex h-10 w-10 items-center justify-center lg:hidden"
    type="button"
    aria-label="Abrir menú de navegación"
    aria-expanded="false"
    aria-controls="mobile-menu"
  >
    <div class="flex w-5 flex-col items-end gap-[5px]">
      <span
        class="block h-px w-full origin-center bg-ink transition-all duration-300 group-[.is-open]:translate-y-[3px] group-[.is-open]:rotate-45"
      ></span>
      <span
        class="block h-px w-3 origin-center bg-ink transition-all duration-300 group-[.is-open]:scale-x-0 group-[.is-open]:opacity-0"
      ></span>
      <span
        class="block h-px w-full origin-center bg-ink transition-all duration-300 group-[.is-open]:-translate-y-[3px] group-[.is-open]:-rotate-45"
      ></span>
    </div>
  </button>
</nav>

<!-- Mobile Menu -->
<div
  id="mobile-menu"
  class="pointer-events-none fixed inset-0 z-[790] flex flex-col items-center justify-center gap-8 bg-dark/98 opacity-0 backdrop-blur-sm transition-all duration-500 lg:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Menú de navegación"
>
  {
    filteredNavLinks.map((link) => (
      <a
        href={link.href}
        class:list={[
          'mobile-nav-link font-display text-3xl font-thin no-underline opacity-0 transition-colors duration-300',
          isActive(link.href)
            ? 'text-brand'
            : 'text-ink hover:text-brand',
        ]}
        aria-current={isActive(link.href) ? 'page' : undefined}
      >
        {link.label}
      </a>
    ))
  }
  <a
    href={cta.href}
    target="_blank"
    rel="noopener noreferrer"
    class="mobile-nav-link mt-4 border border-brand/40 px-8 py-3 font-sans text-xs font-bold uppercase tracking-[0.16em] text-brand no-underline opacity-0 transition-all duration-300 hover:bg-brand hover:text-white"
  >
    {cta.label}
  </a>
</div>

<script>
  document.addEventListener('astro:page-load', () => {
    const navbar = document.getElementById('navbar');
    let isScrolled = false;

    function updateNavbar() {
      const shouldScroll = window.scrollY > 80;
      if (shouldScroll === isScrolled) return;
      isScrolled = shouldScroll;

      if (!navbar) return;

      if (isScrolled) {
        navbar.style.backgroundColor = 'rgba(20, 18, 18, 0.92)';
        navbar.style.backdropFilter = 'blur(22px)';
        navbar.style.WebkitBackdropFilter = 'blur(22px)';
        navbar.style.paddingTop = '1rem';
        navbar.style.paddingBottom = '1rem';
      } else {
        navbar.style.backgroundColor = '';
        navbar.style.backdropFilter = '';
        navbar.style.WebkitBackdropFilter = '';
        navbar.style.paddingTop = '';
        navbar.style.paddingBottom = '';
      }
    }

    window.addEventListener('scroll', updateNavbar, { passive: true });
    // Reset scroll state for new page
    isScrolled = false;
    updateNavbar();

    // Mobile menu
    const toggle = document.getElementById('mobile-menu-toggle');
    const menu = document.getElementById('mobile-menu');
    let menuOpen = false;

    function setMenu(open: boolean) {
      menuOpen = open;
      toggle?.classList.toggle('is-open', open);
      toggle?.setAttribute('aria-expanded', String(open));

      if (menu) {
        if (open) {
          menu.classList.remove('pointer-events-none', 'opacity-0');
          menu.classList.add('pointer-events-auto', 'opacity-100');
          menu.querySelectorAll('.mobile-nav-link').forEach((link, i) => {
            const el = link as HTMLElement;
            el.style.transition = `opacity 0.5s ease ${0.05 + i * 0.05}s, transform 0.5s ease ${0.05 + i * 0.05}s`;
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
          });
        } else {
          menu.classList.add('pointer-events-none', 'opacity-0');
          menu.classList.remove('pointer-events-auto', 'opacity-100');
          menu.querySelectorAll('.mobile-nav-link').forEach((link) => {
            const el = link as HTMLElement;
            el.style.opacity = '0';
            el.style.transform = 'translateY(16px)';
          });
        }
      }

      document.body.style.overflow = open ? 'hidden' : '';
    }

    // Ensure mobile menu is closed on navigation
    setMenu(false);

    // Init mobile links position
    menu?.querySelectorAll('.mobile-nav-link').forEach((link) => {
      const el = link as HTMLElement;
      el.style.transform = 'translateY(16px)';
    });

    toggle?.addEventListener('click', () => setMenu(!menuOpen));
    menu?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => setMenu(false));
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && menuOpen) {
        setMenu(false);
        toggle?.focus();
      }
    });
  });

  // Update active nav link styles after client-side navigation
  document.addEventListener('astro:after-swap', () => {
    const currentPath = document.location.pathname.replace(/\/$/, '') || '/';

    function isActivePath(href: string): boolean {
      if (href.startsWith('#')) return false;
      const normalized = href.replace(/\/$/, '') || '/';
      if (normalized === '/') return currentPath === '/';
      return currentPath === normalized || currentPath.startsWith(normalized + '/');
    }

    // Update desktop nav links
    document.querySelectorAll<HTMLAnchorElement>('#navbar ul a').forEach((link) => {
      const href = link.getAttribute('href') || '';
      const active = isActivePath(href);

      link.classList.toggle('text-brand', active);
      link.classList.toggle('after:w-full', active);
      link.classList.toggle('text-ink-muted', !active);
      link.classList.toggle('hover:text-ink', !active);
      link.classList.toggle('after:w-0', !active);
      link.classList.toggle('hover:after:w-full', !active);

      if (active) {
        link.setAttribute('aria-current', 'page');
      } else {
        link.removeAttribute('aria-current');
      }
    });

    // Update mobile nav links
    document.querySelectorAll<HTMLAnchorElement>('#mobile-menu a.mobile-nav-link').forEach((link) => {
      const href = link.getAttribute('href') || '';
      const active = isActivePath(href);

      link.classList.toggle('text-brand', active);
      link.classList.toggle('text-ink', !active);

      if (active) {
        link.setAttribute('aria-current', 'page');
      } else {
        link.removeAttribute('aria-current');
      }
    });
  });
</script>
