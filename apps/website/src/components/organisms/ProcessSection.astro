---
// Organism: ProcessSection
// Timeline-style process steps. LIGHT SECTION for contrast rhythm.

import homeData from '@/data/home.json';

const { process } = homeData;
---

<section
  id="proceso"
  class="relative bg-light px-6 py-20 md:px-12 lg:px-24 lg:py-36"
  data-section="06"
  data-sname="Proceso"
>
  <!-- Header -->
  <div class="reveal-el mb-4 flex items-center gap-3 text-[0.62rem] uppercase tracking-[0.22em] text-brand">
    <span class="block h-px w-8 bg-brand"></span>
    {process.eyebrow}
  </div>
  <h2
    class="reveal-el mb-12 font-display text-[clamp(2rem,4vw,3.8rem)] font-normal leading-[1.05] text-dark lg:mb-16"
    style="max-width: 500px; transition-delay: 0.12s;"
  >
    {process.heading} <em class="italic text-brand-dark">{process.headingAccent}</em>
  </h2>

  <!-- Steps -->
  <div class="relative mx-auto max-w-4xl">
    {
      process.steps.map((step, i) => (
        <div
          class={`process-step group grid grid-cols-1 items-start gap-6 border-t border-dark/[0.08] py-10 opacity-0 -translate-x-6 transition-all duration-700 md:grid-cols-[170px_1fr] md:gap-12 lg:gap-16 lg:py-16 ${i === process.steps.length - 1 ? 'border-b border-dark/[0.08]' : ''}`}
          style={`transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1); transition-delay: ${i * 0.12}s;`}
        >
          {/* Big Number */}
          <span class="font-display text-6xl font-thin leading-none text-brand/[0.2] transition-opacity duration-400 group-hover:text-brand/70 lg:text-8xl">
            {step.number}
          </span>

          {/* Content */}
          <div>
            <h3 class="mb-2 font-display text-2xl font-normal leading-[1.05] text-dark lg:mb-3 lg:text-4xl">
              {step.title}
            </h3>
            <p class="max-w-sm text-xs leading-relaxed text-dark/55 lg:text-sm lg:leading-[1.8]">
              {step.description}
            </p>
            <a
              href={step.link.href}
              class="mt-4 inline-flex items-center gap-2 text-[0.6rem] uppercase tracking-[0.18em] text-brand no-underline lg:mt-5"
            >
              {step.link.label}
              <svg
                width="14"
                height="10"
                viewBox="0 0 14 10"
                fill="none"
                class="transition-transform duration-300 group-hover:translate-x-1"
                aria-hidden="true"
              >
                <path d="M9 1l4 4-4 4M0 5h13" stroke="currentColor" stroke-width="1.2" />
              </svg>
            </a>
          </div>
        </div>
      ))
    }
  </div>
</section>

<script>
  document.addEventListener('astro:page-load', () => {
    // Reset elements so animations replay on navigation
    document.querySelectorAll('.process-step').forEach((el) => {
      el.classList.add('opacity-0', '-translate-x-6');
      el.classList.remove('opacity-100', 'translate-x-0');
    });

    const stepObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('opacity-100', 'translate-x-0');
            entry.target.classList.remove('opacity-0', '-translate-x-6');
            stepObs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );

    document.querySelectorAll('.process-step').forEach((el) => stepObs.observe(el));
  });
</script>
