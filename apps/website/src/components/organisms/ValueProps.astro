---
// Organism: ValueProps
// Sticky section with animated counters and feature grid.
// Stats count up driven by scroll progress. Features reveal on scroll.

import homeData from '@/data/home.json';

const { valor } = homeData;
---

<section
  id="s-valor"
  class="relative bg-olive"
  data-section="03"
  data-sname="Valor"
  style="height: 200vh;"
>
  <div class="sticky top-0 h-screen overflow-hidden">
    <div class="absolute inset-0 flex flex-col justify-center px-6 md:px-12 lg:px-24">
      <!-- Eyebrow -->
      <div
        id="valor-label"
        class="mb-6 flex items-center gap-3 text-[0.62rem] uppercase tracking-[0.22em] text-brand opacity-0 -translate-x-5 transition-all duration-700 lg:mb-8"
      >
        <span class="block h-px w-8 bg-brand"></span>
        {valor.eyebrow}
      </div>

      <!-- Heading -->
      <h2
        id="valor-title"
        class="mb-10 font-display text-[clamp(2rem,4vw,3.8rem)] font-normal leading-[1.05] text-ink opacity-0 translate-y-8 transition-all duration-700 delay-100 lg:mb-16"
      >
        {valor.heading}
        <em class="italic text-sand">{valor.headingAccent}</em>
      </h2>

      <!-- Stats -->
      <div
        class="mb-12 flex flex-col gap-0 border-t border-ink/[0.12] pt-8 sm:flex-row lg:mb-20 lg:pt-12"
      >
        {
          valor.stats.map((stat, i) => (
            <div
              class={`flex-1 px-4 py-4 sm:px-8 lg:px-12 ${i > 0 ? 'border-t border-ink/[0.12] sm:border-t-0 sm:border-l' : ''} ${i === 0 ? 'sm:pl-0' : ''}`}
            >
              <span
                class="valor-stat block font-display text-[clamp(3rem,5vw,5rem)] font-thin leading-none text-brand"
                data-target={stat.value}
                data-suffix={stat.suffix}
                style="font-variant-numeric: tabular-nums;"
              >
                0
              </span>
              <span class="mt-1 block text-[0.62rem] uppercase tracking-[0.16em] text-ink/50">
                {stat.label}
              </span>
            </div>
          ))
        }
      </div>

      <!-- Features Grid -->
      <div id="valor-features" class="grid grid-cols-1 gap-0 md:grid-cols-3">
        {
          valor.features.map((feat, i) => (
            <div
              class={`valor-feature p-6 opacity-0 translate-y-8 transition-all duration-700 hover:bg-ink/[0.05] lg:p-10 ${i > 0 ? 'border-t border-ink/[0.12] md:border-t-0 md:border-l' : ''} ${i === 0 ? 'md:pl-0' : ''}`}
              style={`transition-delay: ${i * 0.12}s;`}
            >
              <span class="mb-4 block font-display text-base italic text-brand lg:mb-5">
                {feat.number}
              </span>
              <h3 class="mb-2 font-display text-lg font-medium leading-tight text-ink lg:mb-3 lg:text-xl">
                {feat.title}
              </h3>
              <p class="text-xs leading-relaxed text-ink/50 lg:text-sm lg:leading-[1.75]">
                {feat.description}
              </p>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  function initValor() {
    const section = document.getElementById('s-valor');
    const label = document.getElementById('valor-label');
    const title = document.getElementById('valor-title');
    const statEls = document.querySelectorAll('.valor-stat');
    const features = document.querySelectorAll('.valor-feature');

    if (!section) return;

    const clamp = (v: number, min: number, max: number) => Math.max(min, Math.min(max, v));
    const map = (v: number, a: number, b: number, c: number, d: number) =>
      c + (d - c) * clamp((v - a) / (b - a), 0, 1);

    function animate() {
      const h = section.offsetHeight - window.innerHeight;
      const p = h > 0 ? clamp(-section.getBoundingClientRect().top / h, 0, 1) : 0;

      // Counter animation
      statEls.forEach((el, i) => {
        const htmlEl = el as HTMLElement;
        const target = parseInt(htmlEl.dataset.target || '0', 10);
        const suffix = htmlEl.dataset.suffix || '';
        const startP = 0.1 + i * 0.05;
        const endP = 0.6 + i * 0.05;
        const val = Math.round(map(p, startP, endP, 0, target));
        htmlEl.textContent = val + (p > endP ? suffix : '');
      });

      // Reveal elements
      if (p > 0.05 && label) {
        label.classList.add('opacity-100', 'translate-x-0');
        label.classList.remove('opacity-0', '-translate-x-5');
      }
      if (p > 0.1 && title) {
        title.classList.add('opacity-100', 'translate-y-0');
        title.classList.remove('opacity-0', 'translate-y-8');
      }
      if (p > 0.2) {
        features.forEach((f) => {
          f.classList.add('opacity-100', 'translate-y-0');
          f.classList.remove('opacity-0', 'translate-y-8');
        });
      }

      requestAnimationFrame(animate);
    }

    animate();
  }

  if (document.getElementById('loader')) {
    document.addEventListener('loader:complete', initValor, { once: true });
  } else {
    initValor();
  }
</script>
