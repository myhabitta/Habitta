---
// Organism: Manifesto
// Sticky section with word-by-word scroll reveal.
// Words cascade in based on scroll progress. Accent words highlighted in sand color.

import homeData from '@/data/home.json';

const { manifesto } = homeData;
---

<section
  id="s-manifesto"
  class="relative"
  data-section="02"
  data-sname="Manifesto"
  style="height: 250vh;"
>
  <div class="sticky top-0 h-screen overflow-hidden">
    <!-- Horizontal rule that grows on scroll -->
    <div
      id="manifesto-rule"
      class="absolute left-0 top-1/2 h-px w-0 bg-brand/[0.13]"
    ></div>

    <div class="absolute inset-0 flex flex-col justify-center px-6 md:px-12 lg:px-24">
      <!-- Eyebrow -->
      <p class="mb-8 flex items-center gap-3 text-[0.62rem] uppercase tracking-[0.22em] text-brand lg:mb-12">
        <span class="block h-px w-8 bg-brand"></span>
        {manifesto.eyebrow}
      </p>

      <!-- Quote with word-by-word reveal -->
      <blockquote
        id="manifesto-quote"
        class="font-display text-[clamp(2rem,5.5vw,5.5rem)] font-thin italic leading-[1.08] tracking-tight max-w-[900px]"
      >
        {
          manifesto.words.map((word) => {
            const isAccent = manifesto.accentWords.includes(word);
            return (
              <span class="inline-block overflow-hidden align-bottom mr-[0.35em]">
                <span
                  class={`manifesto-word inline-block translate-y-full ${isAccent ? 'text-sand not-italic' : ''}`}
                >
                  {word}
                </span>
              </span>
            );
          })
        }
      </blockquote>

      <!-- Footer -->
      <div
        id="manifesto-footer"
        class="mt-10 flex flex-col gap-3 opacity-0 sm:flex-row sm:items-center sm:gap-8 lg:mt-14"
      >
        <span class="text-xs tracking-[0.1em] text-muted">{manifesto.footer}</span>
        <span class="flex items-center gap-2 text-brand">
          <svg width="28" height="1" viewBox="0 0 28 1" aria-hidden="true">
            <line x1="0" y1=".5" x2="28" y2=".5" stroke="currentColor"></line>
          </svg>
          <span class="text-xs tracking-[0.1em]">{manifesto.cities}</span>
        </span>
      </div>
    </div>
  </div>
</section>

<script>
  function initManifesto() {
    const section = document.getElementById('s-manifesto');
    const rule = document.getElementById('manifesto-rule');
    const footer = document.getElementById('manifesto-footer');
    const words = document.querySelectorAll('.manifesto-word');

    if (!section || !rule || !footer || words.length === 0) return;

    const clamp = (v: number, min: number, max: number) => Math.max(min, Math.min(max, v));
    const map = (v: number, a: number, b: number, c: number, d: number) =>
      c + (d - c) * clamp((v - a) / (b - a), 0, 1);
    const lerp = (a: number, b: number, t: number) => a + (b - a) * t;

    function animate() {
      const h = section.offsetHeight - window.innerHeight;
      const p = h > 0 ? clamp(-section.getBoundingClientRect().top / h, 0, 1) : 0;

      // Words cascade
      words.forEach((w, i) => {
        const start = map(i, 0, words.length - 1, 0.05, 0.8);
        const end = start + 0.2;
        const wp = map(p, start, end, 0, 1);
        (w as HTMLElement).style.transform = `translateY(${lerp(110, 0, wp)}%)`;
      });

      // Rule grows
      rule.style.width = map(p, 0.1, 0.6, 0, 100) + '%';

      // Footer fade
      footer.style.opacity = String(map(p, 0.6, 0.85, 0, 1));

      requestAnimationFrame(animate);
    }

    animate();
  }

  if (document.getElementById('loader')) {
    document.addEventListener('loader:complete', initManifesto, { once: true });
  } else {
    initManifesto();
  }
</script>
