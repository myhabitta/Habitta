{
  "name": "habitta",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,astro,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,astro,json,md}\"",
    "email:dev": "pnpm --filter @habitta/email email:dev"
  },
  "devDependencies": {
    "@react-email/ui": "6.1.5",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.8.20",
    "typescript": "^5.7.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}
