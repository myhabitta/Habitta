---
// Organism: ManifestoAbout
// "El hogar no se compra" — LIGHT SECTION. Bold statement with word-by-word emphasis.
// Editorial manifesto for the about page.
---

<section class="relative px-6 py-24 md:px-12 md:py-32 lg:px-24 lg:py-40 bg-olive">
  <div class="mx-auto max-w-5xl">
    <!-- Eyebrow -->
    <div
      class="manifesto-about-el mb-10 flex items-center gap-3 opacity-0 -translate-x-6 transition-all duration-700 lg:mb-14"
      style="transition-timing-function: cubic-bezier(0.16,1,0.3,1);"
    >
      <span class="block h-px w-10 bg-brand"></span>
      <span class="text-[0.6rem] uppercase tracking-[0.25em] text-brand font-bold"
        >Nuestro manifiesto</span
      >
    </div>

    <!-- Big statement -->
    <h2
      class="manifesto-about-el font-display text-[clamp(2.2rem,5.5vw,5rem)] font-normal leading-[1.15] tracking-tight opacity-0 translate-y-12 transition-all duration-[1.1s]"
      style="transition-timing-function: cubic-bezier(0.16,1,0.3,1); transition-delay: 0.1s;"
    >
      El hogar no se compra,<br />
      <em class="italic text-brand">se construye</em> con quienes<br />
      entienden tu visión.
    </h2>

    <!-- Supporting text + line -->
    <div
      class="manifesto-about-el mt-10 max-w-lg opacity-0 translate-y-8 transition-all duration-[0.9s] lg:mt-14"
      style="transition-timing-function: cubic-bezier(0.16,1,0.3,1); transition-delay: 0.3s;"
    >
      <div class="mb-6 h-px w-16 bg-brand/30"></div>
      <p class="text-sm leading-[1.85] text-ink font-medium">
        No vendemos metros cuadrados — entregamos el espacio donde tu familia va a crecer, celebrar
        y descansar. Esa responsabilidad define cada decisión que tomamos.
      </p>
    </div>
  </div>

  <!-- Decorative large quote mark -->
  <span
    class="pointer-events-none absolute -bottom-8 right-[5%] select-none font-display text-[14rem] font-thin leading-none text-brand/[0.07] md:text-[20rem] lg:text-[26rem]"
    aria-hidden="true"
  >
    &rdquo;
  </span>
</section>

<script>
  const maObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          el.style.opacity = '1';
          el.style.transform = 'translateY(0) translateX(0)';
          maObs.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll('.manifesto-about-el').forEach((el) => maObs.observe(el));
</script>
