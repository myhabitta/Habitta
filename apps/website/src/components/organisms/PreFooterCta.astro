---
// Organism: banda CTA antes del footer (contenido de landing / home).
import ArrowRight from '@/icons/ArrowRight.astro';
import homeData from '@/data/home.json';

const { preCta } = homeData;
---

<section class="bg-surface-accent" aria-label="Llamado a la acción">
  <div class="mx-auto flex w-full max-w-[1400px] flex-col items-start justify-between gap-6 px-[clamp(1.5rem,6vw,5rem)] py-16 sm:flex-row sm:items-center">
    <h2 class="font-primary text-3xl font-light leading-tight text-ink md:text-4xl">
      {preCta.heading}<br />
      <em class="text-primary">{preCta.headingAccent}</em>?
    </h2>
    <a
      href={preCta.cta.href}
      class="group inline-flex items-center gap-2 bg-primary px-7 py-3 font-secondary text-sm font-medium text-white no-underline transition-all duration-300 hover:bg-dark hover:shadow-lg hover:shadow-primary/15"
    >
      <span>{preCta.cta.label}</span>
      <ArrowRight class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" />
    </a>
  </div>
</section>
