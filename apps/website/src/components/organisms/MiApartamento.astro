---
// Organism: MiApartamento
// Showcases the client portal "Mi Apartamento" — a key differentiator.
// DARK SECTION to maintain alternating rhythm after Manifesto (light).

import homeData from '@/data/home.json';

const { miApartamento } = homeData;
const { mockup } = miApartamento;

const dotColors: Record<string, string> = {
  complete: '#22c55e',
  active: '#0ea5e9',
  pending: '#e5e7eb',
};
const lineColors: Record<string, string> = {
  complete: '#22c55e60',
  active: '#e5e7eb',
  pending: '#e5e7eb',
};
---

<section
  id="mi-apartamento"
  class="relative overflow-hidden bg-dark px-6 py-20 md:px-12 lg:px-24 lg:py-36"
  data-section="03"
  data-sname="MiApartamento"
>
  <div class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-20">
    <!-- Left: Text Content -->
    <div>
      <div class="reveal-el mb-4 flex items-center gap-3 text-[0.62rem] uppercase tracking-[0.22em] text-brand">
        <span class="block h-px w-8 bg-brand"></span>
        {miApartamento.eyebrow}
      </div>

      <h2
        class="reveal-el mb-6 font-display text-[clamp(2rem,4vw,3.8rem)] font-normal leading-[1.05] text-ink"
        style="transition-delay: 0.12s;"
      >
        {miApartamento.heading} <em class="italic text-sand">{miApartamento.headingAccent}</em>
      </h2>

      <p
        class="reveal-el mb-10 max-w-md text-sm leading-relaxed text-ink-muted"
        style="transition-delay: 0.24s;"
      >
        {miApartamento.description}
      </p>

      <!-- Feature Grid -->
      <div class="mb-10 grid grid-cols-1 gap-6 sm:grid-cols-2">
        {miApartamento.features.map((feature, i) => (
          <div
            class="mi-apt-feature flex items-start gap-3 opacity-0 translate-y-4 transition-all duration-700"
            style={`transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1); transition-delay: ${0.1 + i * 0.1}s;`}
          >
            <div class="mt-0.5 flex h-8 w-8 shrink-0 items-center justify-center rounded-md bg-brand/10">
              {feature.icon === 'pulse' && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-brand">
                  <path d="M3 12h4l3-9 4 18 3-9h4" />
                </svg>
              )}
              {feature.icon === 'bell' && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-brand">
                  <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9M13.73 21a2 2 0 0 1-3.46 0" />
                </svg>
              )}
              {feature.icon === 'layers' && (
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="text-brand">
                  <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
                </svg>
              )}
            </div>
            <div>
              <h3 class="text-xs font-medium uppercase tracking-wide text-ink">{feature.title}</h3>
              <p class="mt-1 text-xs leading-relaxed text-ink-muted">{feature.description}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <a
        href={miApartamento.cta.href}
        class="reveal-el group inline-flex items-center gap-2 text-[0.62rem] uppercase tracking-[0.22em] text-brand no-underline"
        style="transition-delay: 0.5s;"
      >
        {miApartamento.cta.label}
        <svg
          width="14"
          height="10"
          viewBox="0 0 14 10"
          fill="none"
          class="transition-transform duration-300 group-hover:translate-x-1"
          aria-hidden="true"
        >
          <path d="M9 1l4 4-4 4M0 5h13" stroke="currentColor" stroke-width="1.2" />
        </svg>
      </a>
    </div>

    <!-- Right: CSS-only Portal Mockup (matches real portal light theme) -->
    <div class="mi-apt-mockup flex justify-center opacity-0 translate-y-8 transition-all duration-1000 lg:justify-end" style="transition-timing-function: cubic-bezier(0.16, 1, 0.3, 1);">
      <!-- Phone Frame -->
      <div class="relative w-[280px] sm:w-[300px]">
        <!-- Phone Bezel -->
        <div class="rounded-[2rem] border border-ink/[0.08] bg-surface-raised p-3 shadow-2xl shadow-black/40">
          <!-- Notch -->
          <div class="mx-auto mb-3 h-5 w-24 rounded-full bg-dark"></div>

          <!-- Screen Content — Light theme like real portal -->
          <div class="overflow-hidden rounded-2xl" style="background: linear-gradient(180deg, #f8faf9 0%, #e0f2fe 100%);">
            <!-- App Header — teal chrome -->
            <div class="flex items-center justify-between px-4 py-3" style="border-bottom: 1px solid #e5e7eb;">
              <div class="flex items-center gap-2">
                <div class="flex h-6 w-6 items-center justify-center rounded-md" style="background: #0d948815;">
                  <span class="text-[0.5rem] font-bold" style="color: #0d9488;">H</span>
                </div>
                <span class="text-[0.65rem] font-semibold tracking-wide" style="color: #0d9488;">Mi Apartamento</span>
              </div>
              <div class="flex h-7 w-7 items-center justify-center rounded-full" style="background: linear-gradient(135deg, #0d9488, #0f766e);">
                <span class="text-[0.45rem] font-bold text-white">CM</span>
              </div>
            </div>

            <!-- Unit + Client Name -->
            <div class="px-4 pt-3 pb-2">
              <p class="text-[0.55rem] font-medium uppercase tracking-[0.15em]" style="color: #9b9490;">{mockup.unit}</p>
              <h4 class="mt-0.5 font-display text-sm font-bold" style="color: #1e1a1b;">Carolina Mejía</h4>
            </div>

            <!-- Celebration Banner — phase 3 green -->
            <div class="mx-4 rounded-xl p-3" style="background: linear-gradient(135deg, white 0%, #dcfce7 100%); border: 1px solid #22c55e20; box-shadow: 0 2px 12px #22c55e08;">
              <div class="flex items-start gap-2.5">
                <div class="flex h-9 w-9 shrink-0 items-center justify-center rounded-xl text-base" style="background: #dcfce7;">
                  🎨
                </div>
                <div class="min-w-0 flex-1">
                  <p class="font-display text-[0.7rem] font-bold" style="color: #15803d;">¡Los acabados llegan!</p>
                  <p class="mt-0.5 text-[0.5rem]" style="color: #6b635d;">Tu apartamento se transforma</p>
                  <span class="mt-1 inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-[0.45rem] font-semibold" style="background: #dcfce7; color: #15803d; border: 1px solid #22c55e20;">
                    <span class="relative flex h-1.5 w-1.5">
                      <span class="absolute inline-flex h-full w-full animate-ping rounded-full opacity-75" style="background: #22c55e;"></span>
                      <span class="relative inline-flex h-1.5 w-1.5 rounded-full" style="background: #22c55e;"></span>
                    </span>
                    ¡Vamos con todo!
                  </span>
                </div>
              </div>
            </div>

            <!-- Progress Card — white card -->
            <div class="mx-4 mt-2.5 rounded-xl p-3" style="background: rgba(255,255,255,0.9); border: 1px solid #22c55e15; box-shadow: 0 2px 8px rgba(0,0,0,0.03);">
              <div class="flex items-center justify-between">
                <span class="text-[0.55rem] font-medium uppercase tracking-[0.12em]" style="color: #9b9490;">Progreso general</span>
                <span class="font-display text-lg font-bold" style="color: #15803d;">
                  {mockup.progress}<span class="text-xs" style="color: #c5c0ba;">%</span>
                </span>
              </div>
              <!-- Progress Bar -->
              <div class="mt-2 h-1.5 w-full overflow-hidden rounded-full" style="background: #f3f1ed;">
                <div
                  class="mi-apt-bar h-full rounded-full"
                  style="width: 0%; background: linear-gradient(90deg, #22c55e, #15803d);"
                  data-target={mockup.progress}
                ></div>
              </div>
              <div class="mt-2 flex items-center justify-between">
                <span class="rounded-full px-2 py-0.5 text-[0.45rem] font-semibold" style="background: #dcfce7; color: #15803d; border: 1px solid #22c55e20;">
                  Fase 3: Fondeo, Carpintería
                </span>
                <span class="text-[0.45rem]" style="color: #9b9490;">{mockup.projectName}</span>
              </div>
            </div>

            <!-- Info Row — Paquete + Fecha -->
            <div class="mx-4 mt-2.5 flex gap-2">
              <div class="flex-1 rounded-lg px-3 py-2" style="background: rgba(255,255,255,0.8); border: 1px solid #22c55e10;">
                <span class="block text-[0.45rem] font-medium uppercase tracking-[0.12em]" style="color: #9b9490;">Paquete</span>
                <span class="mt-0.5 block text-[0.6rem] font-semibold" style="color: #15803d;">Premium</span>
              </div>
              <div class="flex-1 rounded-lg px-3 py-2" style="background: rgba(255,255,255,0.8); border: 1px solid #22c55e10;">
                <span class="block text-[0.45rem] font-medium uppercase tracking-[0.12em]" style="color: #9b9490;">Inicio de obra</span>
                <span class="mt-0.5 block text-[0.6rem] font-semibold" style="color: #1e1a1b;">15 marzo 2026</span>
              </div>
            </div>

            <!-- Mini Timeline -->
            <div class="px-4 pt-3 pb-4">
              <div class="flex items-center gap-0">
                {mockup.phases.map((phase, i) => (
                    <div class="flex flex-1 flex-col items-center">
                      <div class="flex w-full items-center">
                        <div
                          class:list={[
                            'h-2.5 w-2.5 shrink-0 rounded-full',
                            { 'animate-pulse-dot': phase.status === 'active' },
                          ]}
                          style={`background: ${dotColors[phase.status]}; ${phase.status === 'active' ? `box-shadow: 0 0 0 3px ${dotColors[phase.status]}30;` : ''}`}
                        ></div>
                        {i < mockup.phases.length - 1 && (
                          <div class="h-px flex-1" style={`background: ${lineColors[phase.status]};`}></div>
                        )}
                      </div>
                      <span
                        class="mt-1.5 text-[0.45rem] font-medium leading-tight"
                        style={`color: ${phase.status === 'active' ? '#0ea5e9' : phase.status === 'complete' ? '#15803d' : '#c5c0ba'};`}
                      >{phase.name}</span>
                    </div>
                ))}
              </div>
            </div>
          </div>
        </div>

        <!-- Decorative glow — teal tint -->
        <div class="absolute -inset-8 -z-10 rounded-[3rem] blur-2xl" style="background: rgba(13,148,136,0.06);"></div>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('astro:page-load', () => {
    // Reset features so animations replay on navigation
    document.querySelectorAll('.mi-apt-feature').forEach((el) => {
      el.classList.add('opacity-0', 'translate-y-4');
      el.classList.remove('opacity-100', 'translate-y-0');
    });

    const featureObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('opacity-100', 'translate-y-0');
            entry.target.classList.remove('opacity-0', 'translate-y-4');
            featureObs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );

    document.querySelectorAll('.mi-apt-feature').forEach((el) => featureObs.observe(el));

    // Reset mockup so animation replays on navigation
    const mockupEl = document.querySelector('.mi-apt-mockup');
    if (mockupEl) {
      mockupEl.classList.add('opacity-0', 'translate-y-8');
      mockupEl.classList.remove('opacity-100', 'translate-y-0');
      const bar = mockupEl.querySelector('.mi-apt-bar') as HTMLElement;
      if (bar) {
        bar.style.transition = 'none';
        bar.style.width = '0%';
      }
    }

    const mockupObs = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('opacity-100', 'translate-y-0');
            entry.target.classList.remove('opacity-0', 'translate-y-8');

            setTimeout(() => {
              const bar = entry.target.querySelector('.mi-apt-bar') as HTMLElement;
              if (bar) {
                const target = bar.dataset.target || '0';
                bar.style.transition = 'width 1.4s cubic-bezier(0.16, 1, 0.3, 1)';
                bar.style.width = target + '%';
              }
            }, 400);

            mockupObs.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2 }
    );

    if (mockupEl) mockupObs.observe(mockupEl);
  });
</script>
